{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/task-envelope.schema.json",
  "title": "Task Envelope",
  "description": "Task envelope 只保存使用者需求與流程控制資訊；runtime preflight 規則、預檢結果與派工裁決屬於 execution manifest、Wrapper 與 Dispatcher 範圍。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "project",
    "request",
    "source",
    "priority",
    "requires_human_approval",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-[0-9]{8}-[0-9]{3,}$"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "request": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": [
        "telegram",
        "web",
        "cli",
        "api",
        "manual"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high",
        "urgent"
      ]
    },
    "requires_human_approval": {
      "type": "boolean"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "approval_note": {
      "type": "string"
    },
    "metadata": {
      "type": "object"
    }
  }
}
